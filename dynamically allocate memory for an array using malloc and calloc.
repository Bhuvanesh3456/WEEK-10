#include <stdio.h>
#include <stdlib.h>
 
int main()
{
  	int n, i;
  	int *arrM, *arrC;
  	printf("25331A05F0\n");
  	printf("Enter size: ");
  	scanf("%d", &n);
  	arrM = (int*) malloc(n * sizeof(int));
  	arrC = (int*) calloc(n, sizeof(int));
  	if (!arrM || !arrC) { printf("Allocation failed\n"); return 1; }
  	printf("calloc initialises to zero: ");
  	for (i = 0; i < n; i++) printf("%d ", arrC[i]);
  	printf("\n");
  	free(arrM);
  	free(arrC);
  	return 0;
}
