#include <stdio.h>
 
int main()
{
  	int arr[5], i;
  	int *ptr = arr;
  	printf("25331A05F0\n");
  	printf("Enter 5 elements: ");
  	for (i = 0; i < 5; i++)
        	scanf("%d", ptr + i);
  	printf("Array via pointer:\n");
  	for (i = 0; i < 5; i++)
        	printf("arr[%d] = %d\n", i, *(ptr + i));
  	return 0;
}

